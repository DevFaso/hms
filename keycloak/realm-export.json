{
  "realm": "hms",
  "displayName": "HMS \u2014 Hospital Management System",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "userManagedAccessAllowed": false,
  "attributes": {
    "userProfileEnabled": "true",
    "unmanagedAttributePolicy": "ENABLED"
  },
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 172800,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername() and passwordHistory(5)",
  "defaultRole": {
    "name": "default-roles-hms",
    "composite": true,
    "clientRole": false,
    "containerId": "hms"
  },
  "roles": {
    "realm": [
      {
        "name": "ROLE_SUPER_ADMIN",
        "description": "Platform super administrator (no tenant scope)"
      },
      {
        "name": "ROLE_HOSPITAL_ADMIN",
        "description": "Hospital-scoped administrator"
      },
      {
        "name": "ROLE_DOCTOR",
        "description": "Physician / attending provider"
      },
      {
        "name": "ROLE_NURSE",
        "description": "Registered nurse"
      },
      {
        "name": "ROLE_PATIENT",
        "description": "Patient portal user"
      },
      {
        "name": "ROLE_RECEPTIONIST",
        "description": "Front-desk / registration"
      },
      {
        "name": "ROLE_STAFF",
        "description": "Generic staff (baseline)"
      },
      {
        "name": "ROLE_LAB_SCIENTIST",
        "description": "Lab scientist"
      },
      {
        "name": "ROLE_LAB_DIRECTOR",
        "description": "Lab director"
      },
      {
        "name": "ROLE_QUALITY_MANAGER",
        "description": "Quality / compliance manager"
      },
      {
        "name": "ROLE_PHARMACIST",
        "description": "Pharmacy dispensing"
      },
      {
        "name": "ROLE_LAB_TECHNICIAN",
        "description": "Lab technician"
      },
      {
        "name": "ROLE_LAB_MANAGER",
        "description": "Lab manager"
      },
      {
        "name": "ROLE_ACCOUNTANT",
        "description": "Finance / accounting"
      },
      {
        "name": "ROLE_RADIOLOGIST",
        "description": "Imaging / radiology"
      },
      {
        "name": "ROLE_SURGEON",
        "description": "Surgeon"
      },
      {
        "name": "ROLE_DENTIST",
        "description": "Dentist"
      },
      {
        "name": "ROLE_MIDWIFE",
        "description": "Midwifery staff"
      },
      {
        "name": "ROLE_BILLING_SPECIALIST",
        "description": "Billing specialist"
      },
      {
        "name": "ROLE_ADMINISTRATIVE_STAFF",
        "description": "Administrative staff"
      },
      {
        "name": "ROLE_SUPPORT_STAFF",
        "description": "Support staff"
      },
      {
        "name": "ROLE_IT_STAFF",
        "description": "IT staff"
      },
      {
        "name": "ROLE_PHARMACY_VERIFIER",
        "description": "Pharmacy dispense verifier"
      },
      {
        "name": "ROLE_INVENTORY_CLERK",
        "description": "Pharmacy inventory clerk"
      },
      {
        "name": "ROLE_STORE_MANAGER",
        "description": "Pharmacy store manager"
      },
      {
        "name": "ROLE_CLAIMS_REVIEWER",
        "description": "Insurance claims reviewer"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "hms-profile",
      "description": "HMS identity-link claims (appUserId, staffId, patientId) + aud=hms-backend",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "audience-hms-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "hms-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "app_user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "app_user_id",
            "claim.name": "appUserId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "staff_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "staff_id",
            "claim.name": "staffId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "patient_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "patient_id",
            "claim.name": "patientId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "hms-claims",
      "description": "HMS custom claims (hospital_id, role_assignments)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "hospital_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "hospital_id",
            "claim.name": "hospital_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role_assignments",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role_assignments",
            "claim.name": "role_assignments",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "web-origins",
      "description": "OpenID Connect scope for add allowed web origins to the access token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "consent.screen.text": "",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "allowed web origins",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-allowed-origins-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
