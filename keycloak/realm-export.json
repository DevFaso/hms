{
  "realm": "hms",
  "displayName": "HMS — Hospital Management System",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,

  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 172800,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,

  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,

  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername() and passwordHistory(5)",

  "defaultRole": {
    "name": "default-roles-hms",
    "composite": true,
    "clientRole": false,
    "containerId": "hms"
  },

  "roles": {
    "realm": [
      { "name": "ROLE_SUPER_ADMIN",          "description": "Platform super administrator (no tenant scope)" },
      { "name": "ROLE_HOSPITAL_ADMIN",       "description": "Hospital-scoped administrator" },
      { "name": "ROLE_DOCTOR",               "description": "Physician / attending provider" },
      { "name": "ROLE_NURSE",                "description": "Registered nurse" },
      { "name": "ROLE_PATIENT",              "description": "Patient portal user" },
      { "name": "ROLE_RECEPTIONIST",         "description": "Front-desk / registration" },
      { "name": "ROLE_STAFF",                "description": "Generic staff (baseline)" },
      { "name": "ROLE_LAB_SCIENTIST",        "description": "Lab scientist" },
      { "name": "ROLE_LAB_DIRECTOR",         "description": "Lab director" },
      { "name": "ROLE_QUALITY_MANAGER",      "description": "Quality / compliance manager" },
      { "name": "ROLE_PHARMACIST",           "description": "Pharmacy dispensing" },
      { "name": "ROLE_LAB_TECHNICIAN",       "description": "Lab technician" },
      { "name": "ROLE_LAB_MANAGER",          "description": "Lab manager" },
      { "name": "ROLE_ACCOUNTANT",           "description": "Finance / accounting" },
      { "name": "ROLE_RADIOLOGIST",          "description": "Imaging / radiology" },
      { "name": "ROLE_SURGEON",              "description": "Surgeon" },
      { "name": "ROLE_DENTIST",              "description": "Dentist" },
      { "name": "ROLE_MIDWIFE",              "description": "Midwifery staff" },
      { "name": "ROLE_BILLING_SPECIALIST",   "description": "Billing specialist" },
      { "name": "ROLE_ADMINISTRATIVE_STAFF", "description": "Administrative staff" },
      { "name": "ROLE_SUPPORT_STAFF",        "description": "Support staff" },
      { "name": "ROLE_IT_STAFF",             "description": "IT staff" },
      { "name": "ROLE_PHARMACY_VERIFIER",    "description": "Pharmacy dispense verifier" },
      { "name": "ROLE_INVENTORY_CLERK",      "description": "Pharmacy inventory clerk" },
      { "name": "ROLE_STORE_MANAGER",        "description": "Pharmacy store manager" },
      { "name": "ROLE_CLAIMS_REVIEWER",      "description": "Insurance claims reviewer" }
    ]
  },

  "clientScopes": [
    {
      "name": "hms-claims",
      "description": "HMS custom claims (hospital_id, role_assignments)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "hospital_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "hospital_id",
            "claim.name": "hospital_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role_assignments",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role_assignments",
            "claim.name": "role_assignments",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "profile",
    "email",
    "roles",
    "web-origins",
    "hms-claims"
  ],

  "clients": [
    {
      "clientId": "hms-backend",
      "name": "HMS Backend (resource server)",
      "description": "Spring Boot resource server. Bearer-only — never initiates a login flow.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "secret": "REPLACE_ME_hms_backend_secret",
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": ["profile", "email", "roles", "hms-claims"],
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "hms-portal",
      "name": "HMS Portal (Angular SPA)",
      "description": "Public client, Auth Code + PKCE only.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/login##https://uat.hms.example.com/login##https://hms.example.com/login",
        "access.token.lifespan": "900"
      },
      "redirectUris": [
        "http://localhost:4200/*",
        "https://uat.hms.example.com/*",
        "https://hms.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "https://uat.hms.example.com",
        "https://hms.example.com"
      ],
      "defaultClientScopes": ["profile", "email", "roles", "web-origins", "hms-claims"]
    },
    {
      "clientId": "hms-android",
      "name": "HMS Patient (Android)",
      "description": "Public mobile client, Auth Code + PKCE via Chrome Custom Tabs.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "com.example.hms.patient://logout",
        "access.token.lifespan": "900"
      },
      "redirectUris": [
        "com.example.hms.patient://oauth/callback"
      ],
      "webOrigins": [],
      "defaultClientScopes": ["profile", "email", "roles", "hms-claims"]
    },
    {
      "clientId": "hms-ios",
      "name": "HMS Patient (iOS)",
      "description": "Public mobile client, Auth Code + PKCE via SFSafariViewController.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "com.example.hms.patient://logout",
        "access.token.lifespan": "900"
      },
      "redirectUris": [
        "com.example.hms.patient://oauth/callback"
      ],
      "webOrigins": [],
      "defaultClientScopes": ["profile", "email", "roles", "hms-claims"]
    }
  ]
}
