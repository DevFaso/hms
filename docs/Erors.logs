    Hibernate: create table billing.billing_invoices (amount_paid numeric(12,2) not null, due_date date not null, invoice_date date not null, total_amount numeric(12,2) not null, created_at timestamp(6) not null, updated_at timestamp(6) not null, created_by uuid, encounter_id uuid, hospital_id uuid not null, id uuid not null, patient_id uuid not null, updated_by uuid, invoice_number varchar(50) not null, notes varchar(2048), status enum ('CANCELLED','DRAFT','PAID','PARTIALLY_PAID','SENT') not null, primary key (id), constraint uk_bi_invoice_number unique (invoice_number), check (amount_paid <= total_amount))
    Hibernate: create table billing.invoice_items (quantity integer not null, total_price numeric(12,2) not null, unit_price numeric(12,2) not null, created_at timestamp(6) not null, updated_at timestamp(6) not null, assignment_id uuid not null, billing_invoice_id uuid not null, id uuid not null, related_service_id uuid, item_description varchar(255) not null, item_category enum ('GENERAL','LAB_TEST','MEDICATION','SERVICE') not null, primary key (id))
    Hibernate: create table billing.payment_transactions (amount numeric(12,2) not null, payment_date date not null, created_at timestamp(6) not null, updated_at timestamp(6) not null, id uuid not null, invoice_id uuid not null, recorded_by uuid, reference_number varchar(120), notes varchar(1024), payment_method enum ('BANK_TRANSFER','CASH','CHECK','CREDIT_CARD','DEBIT_CARD','INSURANCE','OTHER') not null, primary key (id), check (amount > 0))
    Hibernate: create index billing.idx_bi_patient on billing.billing_invoices (patient_id)
    Hibernate: create index billing.idx_bi_hospital on billing.billing_invoices (hospital_id)
    Hibernate: create index billing.idx_item_invoice on billing.invoice_items (billing_invoice_id)
    Hibernate: create index billing.idx_item_assignment on billing.invoice_items (assignment_id)
    Hibernate: create index billing.idx_item_service on billing.invoice_items (related_service_id)
    Hibernate: create index billing.idx_pt_invoice on billing.payment_transactions (invoice_id)
    Hibernate: create index billing.idx_pt_payment_date on billing.payment_transactions (payment_date)
    Hibernate: create index billing.idx_pt_method on billing.payment_transactions (payment_method)
    Hibernate: create table clinical.advance_directives (effective_date date, expiration_date date, created_at timestamp(6) not null, last_reviewed_at timestamp(6), updated_at timestamp(6) not null, hospital_id uuid not null, id uuid not null, patient_id uuid not null, source_system varchar(100), description varchar(1024), document_location varchar(255), physician_name varchar(255), witness_name varchar(255), directive_type enum ('DO_NOT_RESUSCITATE','DURABLE_POWER_OF_ATTORNEY','LIVING_WILL','OTHER','PHYSICIAN_ORDERS_FOR_LIFE_SUSTAINING_TREATMENT') not null, status enum ('ACTIVE','EXPIRED','PENDING','REVOKED') not null, primary key (id))
    Hibernate: create table clinical.appointments (appointment_date date not null, end_time time(6) not null, start_time time(6) not null, created_at timestamp(6) not null, updated_at timestamp(6) not null, assignment_id uuid not null, created_by uuid, department_id uuid not null, hospital_id uuid not null, id uuid not null, patient_id uuid not null, staff_id uuid not null, notes varchar(2048), reason varchar(2048), status enum ('CANCELLED','CHECKED_IN','COMPLETED','CONFIRMED','FAILED','IN_PROGRESS','NO_SHOW','PENDING','RESCHEDULED','SCHEDULED','UNKNOWN') not null, primary key (id), constraint uq_appt_staff_slot unique (staff_id, appointment_date, start_time, end_time))
    Hibernate: create table clinical.birth_plan_comfort_items (item_order integer not null, birth_plan_id uuid not null, item varchar(255), primary key (item_order, birth_plan_id))
    Hibernate: create table clinical.birth_plan_medicated_options (option_order integer not null, birth_plan_id uuid not null, option varchar(255), primary key (option_order, birth_plan_id))
