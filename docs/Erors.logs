    Hibernate: create table clinical.education_resource_translations (resource_id uuid not null, translated_title varchar(500), language_code varchar(255) not null, primary key (resource_id, language_code))
    Hibernate: create table clinical.education_resources (average_rating float(53) not null, estimated_duration integer, is_active boolean not null, is_culturally_sensitive boolean not null, is_evidence_based boolean not null, is_high_risk_relevant boolean not null, is_warning_sign_content boolean not null, completion_count bigint not null, created_at timestamp(6) not null, published_at timestamp(6), rating_count bigint not null, updated_at timestamp(6) not null, view_count bigint not null, primary_language varchar(10) not null, hospital_id uuid, id uuid not null, organization_id uuid, created_by varchar(100) not null, last_modified_by varchar(100), thumbnail_url varchar(500), title varchar(500) not null, video_url varchar(500), content_url varchar(1000), evidence_source varchar(1000), description varchar(2000), text_content TEXT, category enum ('BIRTH_PLAN','BREASTFEEDING','EXERCISE','GENETIC_SCREENING','HIGH_RISK_PREGNANCY','LABOR_AND_DELIVERY','MANAGING_DISCOMFORT','MENTAL_HEALTH','NEWBORN_CARE','NUTRITION','POSTPARTUM_CARE','PRENATAL_CARE','PRENATAL_VITAMINS','ULTRASOUND_SCANS','WARNING_SIGNS') not null, resource_type enum ('ARTICLE','CHECKLIST','FAQ','INFOGRAPHIC','INTERACTIVE_MODULE','PODCAST','VIDEO') not null, primary key (id))
    Hibernate: create table clinical.encounter_history (changed_at timestamp(6) not null, encounter_date timestamp(6), encounter_id uuid not null, id uuid not null, change_type varchar(30), changed_by varchar(100), notes varchar(2048), extra_fields TEXT, previous_values TEXT, encounter_type enum ('CONSULTATION','EMERGENCY','FOLLOW_UP','INPATIENT','LAB','OUTPATIENT','SURGERY'), status enum ('ARRIVED','CANCELLED','COMPLETED','IN_PROGRESS','SCHEDULED'), primary key (id))
