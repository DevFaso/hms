    Hibernate: create table clinical.encounter_note_history (changed_at timestamp(6) not null, encounter_id uuid not null, id uuid not null, note_id uuid, change_type varchar(30), changed_by varchar(120), content_snapshot TEXT, metadata_snapshot TEXT, template enum ('SOAP','SOAPIE'), primary key (id))
    Hibernate: create table clinical.encounter_note_links (created_at timestamp(6) not null, linked_at timestamp(6) not null, updated_at timestamp(6) not null, artifact_id uuid not null, id uuid not null, note_id uuid not null, artifact_code varchar(120), artifact_status varchar(120), artifact_display varchar(255), artifact_type enum ('CARE_PLAN','LAB_ORDER','OTHER','PRESCRIPTION','RADIOLOGY_ORDER','REFERRAL') not null, primary key (id), constraint uk_encounter_note_link unique (note_id, artifact_id, artifact_type))
