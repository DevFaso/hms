{
  "appId": "com.bitnesttechs.hms.patient",
  "appName": "MediHub Patient",
  "webDir": "dist",
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "scheme": "MediHub Patient",
    "allowsLinkPreview": false
  },
  "android": {
    "allowMixedContent": true
  },
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["localhost:8081", "*.bitnesttechs.com"]
  }
}
