{
  "annotations": {
    "list": []
  },
  "description": "Hospital Management System – Spring Boot Prometheus metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"hms\"}",
          "legendFormat": "{{area}} – {{id}}"
        }
      ]
    },
    {
      "title": "JVM Memory Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_max_bytes{application=\"hms\"}",
          "legendFormat": "{{area}} – {{id}}"
        }
      ]
    },
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"hms\"}[5m])) by (method, uri, status)",
          "legendFormat": "{{method}} {{uri}} – {{status}}"
        }
      ]
    },
    {
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"hms\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"hms\", status=~\"5..\"}[5m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "title": "Active HTTP Threads",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads{application=\"hms\"}"
        }
      ]
    },
    {
      "title": "System CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "system_cpu_usage{application=\"hms\"}",
          "legendFormat": "System CPU"
        },
        {
          "expr": "process_cpu_usage{application=\"hms\"}",
          "legendFormat": "Process CPU"
        }
      ]
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"hms\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"hms\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"hms\"}",
          "legendFormat": "Pending"
        }
      ]
    },
    {
      "title": "JVM GC Pause Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(jvm_gc_pause_seconds_bucket{application=\"hms\"}[5m])) by (le, cause))",
          "legendFormat": "{{cause}}"
        }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"hms\"}",
          "legendFormat": "Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"hms\"}",
          "legendFormat": "Daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"hms\"}",
          "legendFormat": "Peak"
        }
      ]
    },
    {
      "title": "Log Events Rate (Logback)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "hms-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(logback_events_total{application=\"hms\"}[5m])) by (level)",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "title": "Errors & Warnings (last 1h)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "loki", "uid": "hms-loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{application=\"hms\"} |~ \"(?i)\\\\b(ERROR|WARN)\\\\b\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "All backend logs (live tail)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "loki", "uid": "hms-loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{application=\"hms\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["hms", "spring-boot", "prometheus", "loki"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HMS – Application Metrics & Logs",
  "uid": "hms-app-metrics",
  "version": 2
}
