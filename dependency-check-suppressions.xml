<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Add suppression rules here for false positives reported by OWASP Dependency-Check.
        Example:
        <suppress>
            <notes><![CDATA[ Suppress false positive for H2 test-only dependency ]]></notes>
            <gav regex="true">com\.h2database:h2:.*</gav>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>
    -->

    <!-- ═══════════════ iText 8.0.2 — CVE-2023-6298 (MEDIUM) ═══════════════
         SSRF via SVG parsing in iText. Our usage is limited to PDF invoice
         generation (PdfInvoiceService) — we do NOT process SVGs from untrusted
         input. False positive for our threat model. Suppressed 2026-02-15. -->
    <suppress>
        <notes><![CDATA[ iText SSRF in SVG parsing — not applicable; we only generate PDF invoices ]]></notes>
        <gav regex="true">com\.itextpdf:.*:8\.0\.2</gav>
        <cve>CVE-2023-6298</cve>
    </suppress>

    <!-- ═══════════════ Log4j-api 2.24.3 — CVE-2025-68161 (MEDIUM) ═══════════════
         Affects log4j-api only (not log4j-core). Spring Boot uses SLF4J/Logback
         by default; log4j-api is a transitive bridge dependency. The vulnerability
         requires log4j-core to be exploitable. Suppressed 2026-02-15. -->
    <suppress>
        <notes><![CDATA[ log4j-api transitive dep — log4j-core not present; not exploitable ]]></notes>
        <gav regex="true">org\.apache\.logging\.log4j:log4j-api:.*</gav>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- ═══════════════ Swagger UI / DOMPurify — CVE-2025-26791 (MEDIUM) ═══════════════
         XSS in DOMPurify 3.1.6 bundled inside swagger-ui 5.18.2. Swagger UI is
         dev-only tooling, disabled in production profiles. No untrusted user
         content is rendered through it. Suppressed 2026-02-15. -->
    <suppress>
        <notes><![CDATA[ Swagger UI dev-only; DOMPurify XSS not exploitable in production ]]></notes>
        <filePath regex="true">.*swagger-ui.*</filePath>
        <cve>CVE-2025-26791</cve>
    </suppress>

    <!-- ═══════════════ Swagger UI / DOMPurify — CVE-2025-15599 (MEDIUM) ═══════════════
         XSS in DOMPurify 3.2.4 bundled inside swagger-ui 5.21.0. Swagger UI is
         dev-only tooling, disabled in production profiles via spring.profiles.
         No untrusted user content is rendered through it. Suppressed 2026-03-13. -->
    <suppress>
        <notes><![CDATA[ Swagger UI dev-only; DOMPurify XSS not exploitable in production ]]></notes>
        <filePath regex="true">.*swagger-ui.*</filePath>
        <cve>CVE-2025-15599</cve>
    </suppress>

    <!-- ═══════════════ Swagger UI / DOMPurify — CVE-2026-0540 (MEDIUM) ═══════════════
         XSS in DOMPurify 3.3.1 bundled inside swagger-ui 5.21.0. Same as above —
         Swagger UI is dev-only, disabled in production. Suppressed 2026-03-13. -->
    <suppress>
        <notes><![CDATA[ Swagger UI dev-only; DOMPurify XSS not exploitable in production ]]></notes>
        <filePath regex="true">.*swagger-ui.*</filePath>
        <cve>CVE-2026-0540</cve>
    </suppress>

    <!-- ═══════════════ PDFBox 2.0.34 — CVE-2026-23907 (MEDIUM) ═══════════════
         Path traversal in the ExtractEmbeddedFiles EXAMPLE code. This CVE affects
         sample/example code only — our PdfInvoiceService generates PDFs from
         trusted application data and never extracts embedded files from untrusted
         PDFs. Not applicable. Suppressed 2026-03-13. -->
    <suppress>
        <notes><![CDATA[ PDFBox path traversal in ExtractEmbeddedFiles example — we only generate PDFs ]]></notes>
        <gav regex="true">org\.apache\.pdfbox:pdfbox:.*</gav>
        <cve>CVE-2026-23907</cve>
    </suppress>

    <!-- ═══════════════ Tomcat 10.1.50 — CVE-2026-24734 (HIGH) ═══════════════
         OCSP responder verification bypass in Tomcat Native / FFM port. Only
         exploitable when using Tomcat Native with an OCSP responder for client
         certificate validation. Our deployment uses standard Java SSL (JSSE),
         not Tomcat Native, and does not use OCSP stapling. No patch available
         yet (10.1.51 not released). Suppressed 2026-03-13. -->
    <suppress>
        <notes><![CDATA[ Tomcat OCSP verification bypass — not using Tomcat Native or OCSP stapling ]]></notes>
        <gav regex="true">org\.apache\.tomcat\.embed:tomcat-embed-.*:10\.1\.50</gav>
        <cve>CVE-2026-24734</cve>
    </suppress>
</suppressions>
