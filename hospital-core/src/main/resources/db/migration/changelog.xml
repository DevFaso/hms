<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- =================================================================
         V1: Complete schema — all 10 schemas + 153 tables
         Generated from Hibernate entity model to ensure 1:1 alignment
         ================================================================= -->
    <changeSet id="V1-initial-schema" author="hms-team" runOnChange="false">
        <sqlFile path="V1__Initial_Schema.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V1.1: Unique constraints omitted by Hibernate SchemaExport
         Required before V2 (ON CONFLICT (code) needs unique index)
         ================================================================= -->
    <changeSet id="V1.1-add-unique-constraints" author="hms-team" runOnChange="false">
        <sqlFile path="V1_1__add_unique_constraints.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V2: Seed 24 role codes (reference data required at bootstrap)
         ================================================================= -->
    <changeSet id="V2-seed-roles" author="hms-team" runOnChange="false">
        <sqlFile path="V2__seed_roles.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="false"/>
    </changeSet>

    <!-- =================================================================
         V3: Seed DEFAULT_ORG + 6 security policies + security rules
         ================================================================= -->
    <changeSet id="V3-seed-default-org-security" author="hms-team" runOnChange="false">
        <sqlFile path="V3__seed_default_organization_security.sql"
                 relativeToChangelogFile="true"
                 splitStatements="false"
                 stripComments="false"/>
    </changeSet>

    <!-- =================================================================
         V4: Make hospital.staff.license_number nullable
         Non-clinical staff (RECEPTIONIST, ADMIN, etc.) do not hold a
         medical licence. Clinical-role validation is enforced at the
         application layer (StaffServiceImpl.validateLicenseNumber).
         ================================================================= -->
    <changeSet id="V4-staff-license-number-nullable" author="hms-team" runOnChange="false">
        <sqlFile path="V4__staff_license_number_nullable.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V5: Add temp_plain_password column to user_role_hospital_assignment
         Stores the auto-generated plaintext credential only until the user
         verifies their assignment code; cleared immediately after use.
         ================================================================= -->
    <changeSet id="V5-add-temp-plain-password" author="hms-team" runOnChange="false">
        <sqlFile path="V5__add_temp_plain_password.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V6: Repair soft-deleted users who still have active role assignments
         Restores is_deleted=false / is_active=true for any user who is
         soft-deleted but owns at least one active UserRoleHospitalAssignment.
         ================================================================= -->
    <changeSet id="V6-repair-soft-deleted-active-users" author="hms-team" runOnChange="false">
        <!-- validCheckSum: accept the old hash (a.active = true) that was already
             recorded in DATABASECHANGELOG on the dev/uat DB before the column-name
             typo was corrected to a.is_active.  The new hash is accepted automatically.
             Old:  9:675be9a24a8d91736e78ec3f93922422
             New:  9:fd056d3ca3f30133f1ca8fff983343fa  -->
        <validCheckSum>9:675be9a24a8d91736e78ec3f93922422</validCheckSum>
        <sqlFile path="V6__repair_soft_deleted_active_users.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V7: Make chat_messages.assignment_id nullable
         SUPER_ADMIN and users without hospital context may send direct
         messages. assignment is left null in that path; the initial
         schema had NOT NULL which caused a 400 constraint violation.
         ================================================================= -->
    <changeSet id="V7-chat-assignment-nullable" author="hms-team" runOnChange="false">
        <sqlFile path="V7__chat_assignment_nullable.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V8: Fix duplicate staff rows + normalize legacy enum values
         - Deduplicates hospital.staff by keeping the latest row per user_id
         - Re-points departments.head_of_department_staff_id to canonical row
         - Adds UNIQUE INDEX ON hospital.staff(user_id)
         - Normalizes REGISTERED → ADMITTED in patient_hospital_registrations
         - Normalizes LAB_SCIENTIST → LABORATORY_SCIENTIST in staff
         ================================================================= -->
    <changeSet id="V8-fix-staff-unique-normalize-stay-status" author="hms-team" runOnChange="false">
        <sqlFile path="V8__fix_staff_unique_and_normalize_stay_status.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <!-- =================================================================
         V9: Support SYSTEM actor in audit_event_logs
         - Makes user_id nullable so bootstrap/scheduled events can be
           persisted without a real user entity.
         - Adds actor_type (USER|SYSTEM) and actor_label columns.
         - CHECK constraint ensures USER events still require user_id.
         ================================================================= -->
    <changeSet id="V9-audit-system-actor-support" author="hms-team" runOnChange="false">
        <sqlFile path="V9__audit_system_actor_support.sql"
                 relativeToChangelogFile="true"
                 splitStatements="false"
                 stripComments="false"/>
    </changeSet>

    <!-- =================================================================
         V10: Activate hospital-scoped staff assignments created by admin
         Admin-register created assignments with is_active=false due to
         enforceRoleScopeConstraints() confirmation-code workflow. This
         broke JWT hospital claims and /api/me/hospital for all staff.
         ================================================================= -->
    <changeSet id="V10-activate-admin-staff-assignments" author="hms-team" runOnChange="false">
        <sqlFile path="V10__activate_admin_registered_staff_assignments.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

</databaseChangeLog>
