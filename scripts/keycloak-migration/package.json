    "test": "tsx --test src/__tests__/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
