{
  "name": "hms-keycloak-migration",
  "version": "1.0.0",
  "private": true,
  "description": "KC-4 / P-6 — one-shot migration of HMS users + role assignments into a Keycloak realm.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
