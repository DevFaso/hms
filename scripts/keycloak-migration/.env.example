# HMS → Keycloak user migration — example env file.
# Copy to `.env` and fill in real values. Never commit the real `.env`.

HMS_DATABASE_URL=postgres://hms_read:PASSWORD@localhost:5432/hms
KEYCLOAK_BASE_URL=https://auth.example.com
KEYCLOAK_REALM=hms
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=migration-admin
KEYCLOAK_ADMIN_PASSWORD=
# Optional toggles
MIGRATION_DRY_RUN=true
MIGRATION_FORCE_PASSWORD_RESET=true
MIGRATION_REQUIRE_EMAIL_VERIFIED=false
